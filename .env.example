# Copier ce fichier en .env et remplir les valeurs réelles
# Ne jamais committer .env sur GitHub !

TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GMAIL_USER=tonemail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optionnel — laisser vide pour utiliser recipients.json
INPUT_RECIPIENTS=

# Type : digest | alert
INPUT_TYPE=digest

# Activer/désactiver l'envoi email (true/false)
# Mettre false pour tester le pipeline sans envoyer d'email
INPUT_MAIL_ENABLED=false

# (Alerte uniquement)
INPUT_ALERT_SUBJECT=⚡ ALERTE OSINT
INPUT_ALERT_BODY_FR=
INPUT_ALERT_BODY_ES=
